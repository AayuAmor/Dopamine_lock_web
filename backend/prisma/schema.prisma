generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  fullName     String   @map("full_name") @db.VarChar(120)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash")
  bio          String?  @db.VarChar(500)
  avatarUrl    String?  @map("avatar_url")
  timezone     String   @default("Asia/Kathmandu") @db.VarChar(80)
  dailyFocusGoal Int    @default(4) @map("daily_focus_goal")
  preferredMissionDuration Int @default(50) @map("preferred_mission_duration")
  disciplineTitle String @default("DISCIPLINED BUILDER") @map("discipline_title") @db.VarChar(80)
  role         String   @default("user") @db.VarChar(50)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([email], map: "idx_users_email")
  @@map("users")
}
