generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MissionDifficulty {
  Easy
  Medium
  Hard
}

enum MissionStatus {
  Draft
  Ready
  Archived
}

enum MissionSessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

enum BlockRuleType {
  BLOCKED
  ALLOWED
}

enum BlockCategory {
  SOCIAL_MEDIA
  ENTERTAINMENT
  GAMING
  SHOPPING
  NEWS
  ADULT
  CUSTOM
  PRODUCTIVITY
  EDUCATION
}

enum BlockRuleSource {
  CUSTOM
  PRESET
  MISSION
}

enum DisciplineScoreEventSource {
  MISSION_COMPLETION
  MISSION_ABANDONED
  FOCUS_DURATION
  STREAK_BONUS
  BLOCK_RESISTANCE
  HEALTHY_CONSUMPTION
  MANUAL_RECALCULATION
}

enum ConsumptionLogSource {
  MANUAL
  EXTENSION
  IMPORTED
}

model User {
  id                        Int                       @id @default(autoincrement())
  fullName                  String                    @map("full_name") @db.VarChar(120)
  email                     String                    @unique @db.VarChar(255)
  passwordHash              String                    @map("password_hash")
  bio                       String?                   @db.VarChar(500)
  avatarUrl                 String?                   @map("avatar_url")
  timezone                  String                    @default("Asia/Kathmandu") @db.VarChar(80)
  dailyFocusGoal            Int                       @default(4) @map("daily_focus_goal")
  preferredMissionDuration  Int                       @default(50) @map("preferred_mission_duration")
  disciplineTitle           String                    @default("DISCIPLINED BUILDER") @map("discipline_title") @db.VarChar(80)
  role                      String                    @default("user") @db.VarChar(50)
  createdAt                 DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  missions                  Mission[]
  missionSessions           MissionSession[]
  blockRules                BlockRule[]
  userPresetBlockLists      UserPresetBlockList[]
  disciplineScore           DisciplineScore?
  disciplineScoreEvents     DisciplineScoreEvent[]
  disciplineScoreSnapshots  DisciplineScoreSnapshot[]
  consumptionLimits         ConsumptionLimit[]
  consumptionLogs           ConsumptionLog[]
  consumptionDailySummaries ConsumptionDailySummary[]

  @@index([email], map: "idx_users_email")
  @@map("users")
}

model Mission {
  id                    Int               @id @default(autoincrement())
  userId                Int               @map("user_id")
  title                 String            @db.VarChar(140)
  goal                  String            @db.VarChar(220)
  description           String?           @db.VarChar(1000)
  durationMinutes       Int               @map("duration_minutes")
  difficulty            MissionDifficulty
  strictMode            Boolean           @default(true) @map("strict_mode")
  blockNotifications    Boolean           @default(true) @map("block_notifications")
  preventTabSwitching   Boolean           @default(true) @map("prevent_tab_switching")
  blockedWebsites       Json              @default("[]") @map("blocked_websites")
  allowedWebsites       Json              @default("[]") @map("allowed_websites")
  blockedCategories     Json              @default("[]") @map("blocked_categories")
  status                MissionStatus     @default(Ready)
  favorite              Boolean           @default(false)
  archived              Boolean           @default(false)
  sessionCount          Int               @default(0) @map("session_count")
  completedSessionCount Int               @default(0) @map("completed_session_count")
  abandonedSessionCount Int               @default(0) @map("abandoned_session_count")
  lastStartedAt         DateTime?         @map("last_started_at") @db.Timestamptz(6)
  lastCompletedAt       DateTime?         @map("last_completed_at") @db.Timestamptz(6)
  createdAt             DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions              MissionSession[]

  @@index([userId], map: "idx_missions_user_id")
  @@index([userId, archived], map: "idx_missions_user_archived")
  @@index([userId, favorite], map: "idx_missions_user_favorite")
  @@map("missions")
}

model MissionSession {
  id                     Int                    @id @default(autoincrement())
  userId                 Int                    @map("user_id")
  missionId              Int                    @map("mission_id")
  startedAt              DateTime               @default(now()) @map("started_at") @db.Timestamptz(6)
  endedAt                DateTime?              @map("ended_at") @db.Timestamptz(6)
  completedAt            DateTime?              @map("completed_at") @db.Timestamptz(6)
  pausedAt               DateTime?              @map("paused_at") @db.Timestamptz(6)
  totalPausedSeconds     Int                    @default(0) @map("total_paused_seconds")
  elapsedSeconds         Int                    @default(0) @map("elapsed_seconds")
  remainingSeconds       Int                    @default(0) @map("remaining_seconds")
  completionPercentage   Int                    @default(0) @map("completion_percentage")
  actualDurationMinutes  Int?                   @map("actual_duration_minutes")
  plannedDurationMinutes Int?                   @map("planned_duration_minutes")
  focusPercentage        Int?                   @map("focus_percentage")
  interruptionCount      Int                    @default(0) @map("interruption_count")
  blockedWebsitesCount   Int                    @default(0) @map("blocked_websites_count")
  completionReason       String?                @map("completion_reason") @db.VarChar(120)
  status                 MissionSessionStatus   @default(ACTIVE)
  completed              Boolean                @default(false)
  abandoned              Boolean                @default(false)
  notes                  String?                @db.VarChar(1000)
  createdAt              DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                   User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission                Mission                @relation(fields: [missionId], references: [id], onDelete: Cascade)
  disciplineScoreEvents  DisciplineScoreEvent[]

  @@index([userId], map: "idx_mission_sessions_user_id")
  @@index([missionId], map: "idx_mission_sessions_mission_id")
  @@index([userId, status], map: "idx_mission_sessions_user_status")
  @@index([userId, startedAt], map: "idx_mission_sessions_user_started_at")
  @@index([userId, endedAt], map: "idx_mission_sessions_user_ended_at")
  @@index([userId, completedAt], map: "idx_mission_sessions_user_completed_at")
  @@map("mission_sessions")
}

model BlockRule {
  id        Int             @id @default(autoincrement())
  userId    Int             @map("user_id")
  domain    String          @db.VarChar(255)
  type      BlockRuleType
  category  BlockCategory   @default(CUSTOM)
  reason    String?         @db.VarChar(500)
  active    Boolean         @default(true)
  source    BlockRuleSource @default(CUSTOM)
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, domain, type], map: "block_rules_user_domain_type_key")
  @@index([userId], map: "idx_block_rules_user_id")
  @@index([userId, active], map: "idx_block_rules_user_active")
  @@index([userId, type], map: "idx_block_rules_user_type")
  @@map("block_rules")
}

model PresetBlockList {
  id          Int                   @id @default(autoincrement())
  name        String                @unique @db.VarChar(120)
  description String?               @db.VarChar(500)
  category    BlockCategory
  websites    Json                  @default("[]")
  active      Boolean               @default(true)
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  userPresets UserPresetBlockList[]

  @@index([active], map: "idx_preset_block_lists_active")
  @@map("preset_block_lists")
}

model UserPresetBlockList {
  id                Int             @id @default(autoincrement())
  userId            Int             @map("user_id")
  presetBlockListId Int             @map("preset_block_list_id")
  enabled           Boolean         @default(true)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  presetBlockList   PresetBlockList @relation(fields: [presetBlockListId], references: [id], onDelete: Cascade)

  @@unique([userId, presetBlockListId], map: "user_preset_block_lists_user_preset_key")
  @@index([userId, enabled], map: "idx_user_preset_block_lists_user_enabled")
  @@map("user_preset_block_lists")
}

model DisciplineScore {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique @map("user_id")
  totalXp            Int      @default(0) @map("total_xp")
  currentRank        String   @default("D") @map("current_rank") @db.VarChar(20)
  nextRank           String?  @map("next_rank") @db.VarChar(20)
  progressToNextRank Int      @default(0) @map("progress_to_next_rank")
  lastCalculatedAt   DateTime @default(now()) @map("last_calculated_at") @db.Timestamptz(6)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_discipline_scores_user_id")
  @@map("discipline_scores")
}

model DisciplineScoreEvent {
  id               Int                        @id @default(autoincrement())
  userId           Int                        @map("user_id")
  missionSessionId Int?                       @map("mission_session_id")
  source           DisciplineScoreEventSource
  points           Int
  description      String                     @db.VarChar(255)
  metadata         Json                       @default("{}")
  createdAt        DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  user             User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  missionSession   MissionSession?            @relation(fields: [missionSessionId], references: [id], onDelete: SetNull)

  @@unique([source, missionSessionId], map: "discipline_score_events_source_session_key")
  @@index([userId], map: "idx_discipline_score_events_user_id")
  @@index([userId, createdAt], map: "idx_discipline_score_events_user_created_at")
  @@map("discipline_score_events")
}

model DisciplineScoreSnapshot {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  score     Int
  rank      String   @db.VarChar(20)
  date      DateTime @db.Date
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date], map: "discipline_score_snapshots_user_date_key")
  @@index([userId, date], map: "idx_discipline_score_snapshots_user_date")
  @@map("discipline_score_snapshots")
}

model ConsumptionPlatform {
  id        Int                @id @default(autoincrement())
  name      String             @unique @db.VarChar(120)
  slug      String             @unique @db.VarChar(120)
  category  String             @default("SHORT_FORM") @db.VarChar(80)
  domain    String             @db.VarChar(255)
  active    Boolean            @default(true)
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  limits    ConsumptionLimit[]
  logs      ConsumptionLog[]

  @@index([slug], map: "idx_consumption_platforms_slug")
  @@map("consumption_platforms")
}

model ConsumptionLimit {
  id               Int                  @id @default(autoincrement())
  userId           Int                  @map("user_id")
  platformId       Int?                 @map("platform_id")
  maxVideosPerDay  Int                  @default(40) @map("max_videos_per_day")
  maxMinutesPerDay Int                  @default(120) @map("max_minutes_per_day")
  warningThreshold Int                  @default(80) @map("warning_threshold")
  strictLockMode   Boolean              @default(true) @map("strict_lock_mode")
  active           Boolean              @default(true)
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform         ConsumptionPlatform? @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@unique([userId, platformId], map: "consumption_limits_user_platform_key")
  @@index([userId], map: "idx_consumption_limits_user_id")
  @@map("consumption_limits")
}

model ConsumptionLog {
  id              Int                  @id @default(autoincrement())
  userId          Int                  @map("user_id")
  platformId      Int                  @map("platform_id")
  videosWatched   Int                  @default(0) @map("videos_watched")
  minutesConsumed Int                  @default(0) @map("minutes_consumed")
  source          ConsumptionLogSource @default(MANUAL)
  consumedAt      DateTime             @default(now()) @map("consumed_at") @db.Timestamptz(6)
  metadata        Json                 @default("{}")
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform        ConsumptionPlatform  @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt], map: "idx_consumption_logs_user_consumed_at")
  @@index([platformId], map: "idx_consumption_logs_platform_id")
  @@map("consumption_logs")
}

model ConsumptionDailySummary {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  date           DateTime @db.Date
  totalVideos    Int      @default(0) @map("total_videos")
  totalMinutes   Int      @default(0) @map("total_minutes")
  score          Int      @default(100)
  limitReached   Boolean  @default(false) @map("limit_reached")
  warningReached Boolean  @default(false) @map("warning_reached")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date], map: "consumption_daily_summaries_user_date_key")
  @@index([userId, date], map: "idx_consumption_daily_summaries_user_date")
  @@map("consumption_daily_summaries")
}
