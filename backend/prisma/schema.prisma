generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MissionDifficulty {
  Easy
  Medium
  Hard
}

enum MissionStatus {
  Draft
  Ready
  Archived
}

enum MissionSessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

enum BlockRuleType {
  BLOCKED
  ALLOWED
}

enum BlockCategory {
  SOCIAL_MEDIA
  ENTERTAINMENT
  GAMING
  SHOPPING
  NEWS
  ADULT
  CUSTOM
  PRODUCTIVITY
  EDUCATION
}

enum BlockRuleSource {
  CUSTOM
  PRESET
  MISSION
}

model User {
  id           Int      @id @default(autoincrement())
  fullName     String   @map("full_name") @db.VarChar(120)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash")
  bio          String?  @db.VarChar(500)
  avatarUrl    String?  @map("avatar_url")
  timezone     String   @default("Asia/Kathmandu") @db.VarChar(80)
  dailyFocusGoal Int    @default(4) @map("daily_focus_goal")
  preferredMissionDuration Int @default(50) @map("preferred_mission_duration")
  disciplineTitle String @default("DISCIPLINED BUILDER") @map("discipline_title") @db.VarChar(80)
  role         String   @default("user") @db.VarChar(50)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  missions     Mission[]
  missionSessions MissionSession[]
  blockRules   BlockRule[]
  userPresetBlockLists UserPresetBlockList[]

  @@index([email], map: "idx_users_email")
  @@map("users")
}

model Mission {
  id                  Int               @id @default(autoincrement())
  userId              Int               @map("user_id")
  title               String            @db.VarChar(140)
  goal                String            @db.VarChar(220)
  description         String?           @db.VarChar(1000)
  durationMinutes     Int               @map("duration_minutes")
  difficulty          MissionDifficulty
  strictMode          Boolean           @default(true) @map("strict_mode")
  blockNotifications  Boolean           @default(true) @map("block_notifications")
  preventTabSwitching Boolean           @default(true) @map("prevent_tab_switching")
  blockedWebsites     Json              @default("[]") @map("blocked_websites")
  allowedWebsites     Json              @default("[]") @map("allowed_websites")
  blockedCategories   Json              @default("[]") @map("blocked_categories")
  status              MissionStatus     @default(Ready)
  favorite            Boolean           @default(false)
  archived            Boolean           @default(false)
  sessionCount        Int               @default(0) @map("session_count")
  completedSessionCount Int             @default(0) @map("completed_session_count")
  abandonedSessionCount Int             @default(0) @map("abandoned_session_count")
  lastStartedAt       DateTime?         @map("last_started_at") @db.Timestamptz(6)
  lastCompletedAt     DateTime?         @map("last_completed_at") @db.Timestamptz(6)
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions            MissionSession[]

  @@index([userId], map: "idx_missions_user_id")
  @@index([userId, archived], map: "idx_missions_user_archived")
  @@index([userId, favorite], map: "idx_missions_user_favorite")
  @@map("missions")
}

model MissionSession {
  id                   Int                  @id @default(autoincrement())
  userId               Int                  @map("user_id")
  missionId            Int                  @map("mission_id")
  startedAt            DateTime             @default(now()) @map("started_at") @db.Timestamptz(6)
  endedAt              DateTime?            @map("ended_at") @db.Timestamptz(6)
  pausedAt             DateTime?            @map("paused_at") @db.Timestamptz(6)
  totalPausedSeconds   Int                  @default(0) @map("total_paused_seconds")
  elapsedSeconds       Int                  @default(0) @map("elapsed_seconds")
  remainingSeconds     Int                  @default(0) @map("remaining_seconds")
  completionPercentage Int                  @default(0) @map("completion_percentage")
  status               MissionSessionStatus @default(ACTIVE)
  completed            Boolean              @default(false)
  abandoned            Boolean              @default(false)
  notes                String?              @db.VarChar(1000)
  createdAt            DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission              Mission              @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_mission_sessions_user_id")
  @@index([missionId], map: "idx_mission_sessions_mission_id")
  @@index([userId, status], map: "idx_mission_sessions_user_status")
  @@index([userId, startedAt], map: "idx_mission_sessions_user_started_at")
  @@map("mission_sessions")
}

model BlockRule {
  id        Int             @id @default(autoincrement())
  userId    Int             @map("user_id")
  domain    String          @db.VarChar(255)
  type      BlockRuleType
  category  BlockCategory   @default(CUSTOM)
  reason    String?         @db.VarChar(500)
  active    Boolean         @default(true)
  source    BlockRuleSource @default(CUSTOM)
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, domain, type], map: "block_rules_user_domain_type_key")
  @@index([userId], map: "idx_block_rules_user_id")
  @@index([userId, active], map: "idx_block_rules_user_active")
  @@index([userId, type], map: "idx_block_rules_user_type")
  @@map("block_rules")
}

model PresetBlockList {
  id        Int                   @id @default(autoincrement())
  name      String                @unique @db.VarChar(120)
  description String?             @db.VarChar(500)
  category  BlockCategory
  websites  Json                  @default("[]")
  active    Boolean               @default(true)
  createdAt DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  userPresets UserPresetBlockList[]

  @@index([active], map: "idx_preset_block_lists_active")
  @@map("preset_block_lists")
}

model UserPresetBlockList {
  id                Int             @id @default(autoincrement())
  userId            Int             @map("user_id")
  presetBlockListId Int             @map("preset_block_list_id")
  enabled           Boolean         @default(true)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  presetBlockList   PresetBlockList @relation(fields: [presetBlockListId], references: [id], onDelete: Cascade)

  @@unique([userId, presetBlockListId], map: "user_preset_block_lists_user_preset_key")
  @@index([userId, enabled], map: "idx_user_preset_block_lists_user_enabled")
  @@map("user_preset_block_lists")
}
